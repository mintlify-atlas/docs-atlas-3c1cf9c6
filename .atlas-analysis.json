  "keyFeatures": [
    "Axum web framework with async routing",
    "PostgreSQL integration with SQLx",
    "Generic repository pattern with CRUD traits",
    "Built-in filtering and pagination",
    "Docker support with multi-stage builds",
    "Structured logging with tracing"
  ],
  "publicApiSurface": [
    "GET /cities - List cities with filtering and pagination",
    "POST /city - Create a new city",
    "PUT /city/:id - Update an existing city",
    "DELETE /city/:id - Delete a city",
    "Insertable trait - Generic insert operations",
    "Updatable trait - Generic update operations",
    "Deletable trait - Generic delete operations",
    "Listable trait - Generic list with filtering"
  ]
